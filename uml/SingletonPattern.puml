@startuml
' 单例模式 UML 图

' 定义HeroAircraft类
class HeroAircraft {
  -static instance: HeroAircraft
  -locationX: int
  -locationY: int
  -speedX: int
  -speedY: int
  -hp: int
  -power: int
  -shootNum: int
  -direction: int
  -cycle: int
  
  -HeroAircraft()
  +static getInstance(): HeroAircraft
  +reset(): void
  +increaseHp(int hp): void
  +decreaseHp(int damage): void
  +shoot(): List<BaseBullet>
  +forward(): void
  +setLocation(int x, int y): void
  +getLocationX(): int
  +getLocationY(): int
  +getHp(): int
}

' 定义使用HeroAircraft的类
class Game {
  -heroAircraft: HeroAircraft
  +Game(JFrame frame)
  +action(): void
}

class HeroController {
  -game: Game
  -heroAircraft: HeroAircraft
  +HeroController(Game game, HeroAircraft heroAircraft)
}

' 定义关系
Game ..> HeroAircraft
HeroController ..> HeroAircraft

' 标题
title 单例模式 - HeroAircraft
@enduml